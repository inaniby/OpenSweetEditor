{
  "module": {
    "name": "demo",
    "type": "entry",
    "description": "$string:module_desc",
    "mainElement": "DemoAbility",
    "deviceTypes": [
      "phone"
    ],
    "deliveryWithInstall": true,
    "installationFree": false,
    "requestPermissions": [
      {
        "name": "ohos.permission.READ_PASTEBOARD",
        "reason": "$string:pasteboard_reason",
        "usedScene": {
          "abilities": [
            "DemoAbility"
          ],
          "when": "inuse"
        }
      }
    ],
    "pages": "$profile:main_pages",
    "abilities": [
      {
        "name": "DemoAbility",
        "srcEntry": "./ets/demoability/DemoAbility.ets",
        "description": "$string:DemoAbility_desc",
        "icon": "$media:layered_image",
        "label": "$string:DemoAbility_label",
        "startWindowIcon": "$media:startIcon",
        "startWindowBackground": "$color:start_window_background",
        "exported": true,
        "skills": [
          {
            "entities": [
              "entity.system.home"
            ],
            "actions": [
              "ohos.want.action.home"
            ]
          }
        ]
      }
    ],
    "extensionAbilities": [
      {
        "name": "DemoBackupAbility",
        "srcEntry": "./ets/demobackupability/DemoBackupAbility.ets",
        "type": "backup",
        "exported": false,
        "metadata": [
          {
            "name": "ohos.extension.backup",
            "resource": "$profile:backup_config"
          }
        ],
      }
    ]
  }
}
